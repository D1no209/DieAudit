COMPOSE_PROJECT_NAME=dieaudit

POSTGRES_USER=dieaudit
POSTGRES_PASSWORD=dieaudit
POSTGRES_DB=dieaudit

REDIS_PASSWORD=

MINIO_ROOT_USER=dieaudit
MINIO_ROOT_PASSWORD=dieaudit-secret
MINIO_BUCKET_ARTIFACTS=dieaudit-artifacts

NATS_USER=dieaudit
NATS_PASSWORD=dieaudit

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LOCAL_LLM_API_KEY=
DIEAUDIT_API_KEY=
API_KEY_HEADER=X-DieAudit-Api-Key
PUBLIC_METRICS=false
DEFAULT_CONTAINER_MEMORY=1024m
DEFAULT_CONTAINER_CPUS=1.0
DEFAULT_CONTAINER_PIDS_LIMIT=512
DEFAULT_CONTAINER_TMPFS=/tmp:rw,nosuid,size=128m
PLATFORM_AUDIT_EVENT_RETENTION_DAYS=30
PLATFORM_AUDIT_EVENT_MAX_ROWS=10000
PIPELINE_RECOVERY_ON_STARTUP=true

DOCKER_HOST=tcp://docker-socket-proxy:2375

HOST_HTTP_PROXY=http://127.0.0.1:7897
HOST_HTTPS_PROXY=http://127.0.0.1:7897
BUILD_HTTP_PROXY=http://host.docker.internal:7897
BUILD_HTTPS_PROXY=http://host.docker.internal:7897
NO_PROXY=localhost,127.0.0.1,::1,postgres,redis,nats,minio,qdrant,temporal,web-api,agent-gateway,workspace-engine,sandbox-runner,kb-indexer,docker-socket-proxy

DEFAULT_SANDBOX_RUNTIME=runc
ENABLE_GVISOR=false
ALLOW_RUNC_SANDBOX=false

API_PORT=8080
WEB_API_PORT=18000
AGENT_GATEWAY_PORT=18001
TEMPORAL_UI_PORT=18088
MINIO_CONSOLE_PORT=19001
QDRANT_PORT=16333

KNOWLEDGE_COLLECTION_NAME=dieaudit_knowledge_v1
KNOWLEDGE_VECTOR_SIZE=1024
KNOWLEDGE_EMBEDDING_PROVIDER=hash
KNOWLEDGE_EMBEDDING_BASE_URL=
KNOWLEDGE_EMBEDDING_API_KEY=
KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small
KNOWLEDGE_EMBEDDING_TIMEOUT_SECONDS=60
NATS_MONITOR_PORT=18222
