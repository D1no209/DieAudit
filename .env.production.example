COMPOSE_PROJECT_NAME=dieaudit

# Required before exposing the platform. Generate a long random value locally.
DIEAUDIT_API_KEY=change-me-use-a-long-random-secret
API_KEY_HEADER=X-DieAudit-Api-Key
PUBLIC_METRICS=false

# Keep audit execution out of FastAPI request-local background tasks.
PIPELINE_EXECUTION_BACKEND=workflow-worker
PIPELINE_WORKER_POLL_INTERVAL_SECONDS=2
PIPELINE_WORKER_HEARTBEAT_INTERVAL_SECONDS=5
PIPELINE_WORKER_HEARTBEAT_TTL_SECONDS=30
PIPELINE_RECOVERY_ON_STARTUP=true
ENABLE_DEMO_TEMPLATES=false

# Docker proxy for local image pulls/builds.
HOST_HTTP_PROXY=http://127.0.0.1:7897
HOST_HTTPS_PROXY=http://127.0.0.1:7897
BUILD_HTTP_PROXY=http://host.docker.internal:7897
BUILD_HTTPS_PROXY=http://host.docker.internal:7897
NO_PROXY=localhost,127.0.0.1,::1

# Strong sandbox isolation. Install gVisor runsc on the host before enabling.
ENABLE_GVISOR=true
DEFAULT_SANDBOX_RUNTIME=runsc
ALLOW_RUNC_SANDBOX=false

# Production semantic KB retrieval. Use a fresh Qdrant collection after changing dimensions.
KNOWLEDGE_EMBEDDING_PROVIDER=openai-compatible
KNOWLEDGE_EMBEDDING_BASE_URL=https://embedding-provider.example/v1
KNOWLEDGE_EMBEDDING_API_KEY=change-me
KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small
KNOWLEDGE_VECTOR_SIZE=1536
KNOWLEDGE_COLLECTION_NAME=dieaudit_knowledge_embeddings_v1
KNOWLEDGE_EMBEDDING_PROBE_ON_READINESS=true

# Resource limits for dynamic containers.
DEFAULT_CONTAINER_MEMORY=1024m
DEFAULT_CONTAINER_CPUS=1.0
DEFAULT_CONTAINER_PIDS_LIMIT=512
DEFAULT_CONTAINER_TMPFS=/tmp:rw,nosuid,size=128m
